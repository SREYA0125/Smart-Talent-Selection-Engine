generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  RECRUITER
  ADMIN
}

enum JobStatus {
  OPEN
  CLOSED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(RECRUITER)
  jobs      Job[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Job {
  id          String    @id @default(uuid())
  recruiter   User      @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  recruiterId String
  title       String
  description String
  status      JobStatus @default(OPEN)
  resumes     Resume[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Speeds up "get all jobs for this recruiter" — the most common query
  // this module performs, run on every dashboard load.
  @@index([recruiterId])
}


model Resume {
  id           String   @id @default(uuid())
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId        String
  originalName String
  storedName   String   @unique
  filePath     String
  mimeType     String
  fileSize     Int
  createdAt    DateTime @default(now())

  // Speeds up "get all resumes for this job" — the primary read pattern
  // once uploads exist.
  @@index([jobId])
}
