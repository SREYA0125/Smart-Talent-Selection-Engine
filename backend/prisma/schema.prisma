generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  RECRUITER
  ADMIN
}

enum JobStatus {
  OPEN
  CLOSED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(RECRUITER)
  jobs      Job[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Added in the Job Management module. requiredSkills/applications/scoring
// relations are intentionally NOT here yet — they belong to the Resume and
// AI Scoring modules and will be added when those are built, to avoid
// introducing models (Skill, Application, Score) this module doesn't need.
model Job {
  id          String    @id @default(uuid())
  recruiter   User      @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  recruiterId String
  title       String
  description String
  status      JobStatus @default(OPEN)
  resumes     Resume[]
  analyses    Analysis[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Speeds up "get all jobs for this recruiter" — the most common query
  // this module performs, run on every dashboard load.
  @@index([recruiterId])
}

// Added in the Resume Upload module. Stores only file metadata + where the
// physical file lives on disk. `rawText` was added in the Resume Parsing
// module below. Skill/score fields still intentionally do NOT exist here —
// those belong to the AI Scoring module.
model Resume {
  id           String    @id @default(uuid())
  job          Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId        String
  originalName String
  storedName   String    @unique
  filePath     String
  mimeType     String
  fileSize     Int

  // Added in the Resume Parsing module. Nullable rather than required —
  // not because the app should ever create a Resume without text (the
  // controller only inserts a row after parsing succeeds, in one write),
  // but because making it required on a table that may already have rows
  // from the earlier Upload-only module would force a destructive
  // migration. Nullable keeps this migration additive and safe.
  rawText      String?

  // One-to-one: a resume is analyzed against the one job it was uploaded
  // for. Optional or the second analysis run for the same resume would
  // otherwise fail on the unique constraint rather than replacing the old
  // result — the AI Analysis controller decides which behavior it wants.
  analysis     Analysis?

  createdAt    DateTime  @default(now())

  // Speeds up "get all resumes for this job" — the primary read pattern
  // once uploads exist.
  @@index([jobId])
}

// Added in the AI Resume Analysis module. One Analysis belongs to exactly
// one Resume (1:1, enforced by @unique on resumeId) and, redundantly but
// deliberately, to the Job that resume was uploaded against — even though
// that job is already reachable via resume.job. Storing jobId directly here
// means "get all analyses for this job" (needed by the future ranking
// module) is a single indexed query, not a join through Resume every time.
model Analysis {
  id             String   @id @default(uuid())
  resume         Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  resumeId       String   @unique
  job            Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId          String
  overallScore   Int
  matchingSkills String[]
  missingSkills  String[]
  strengths      String[]
  weaknesses     String[]
  summary        String
  createdAt      DateTime @default(now())

  @@index([jobId])
}
